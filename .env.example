# Google Sheets API (서비스 계정 JSON의 값 사용)
# 스프레드시트를 서비스 계정 이메일과 "편집자"로 공유해야 합니다.
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=

# Google Calendar — "기업교육 일정" 같은 캘린더는 Google 캘린더 설정에서 ID 복사 후 아래에 넣으세요.
# GOOGLE_CALENDAR_ID=xxxx@group.calendar.google.com
#
# (선택) 이벤트 제목(summary)에 이 문구가 들어간 것만 표시. 공백 무시.
# 캘린더 이름/라벨과 무관합니다. "기업교육"만 넣으면 [한국전자통신연구원] 같은 제목은 전부 제외되어 0건이 됩니다.
# 대부분은 비워 두고 GOOGLE_CALENDAR_ID 만 쓰면 됩니다.
# GOOGLE_CALENDAR_SUMMARY_FILTER=

# 시트 이름 (동일 스프레드시트 내 시트 탭 이름)
# 로그인: "EM 로그인"(C열=아이디, D열=비밀번호), "실습코치 로그인"(F열=이메일, G열=아이디, H열=비밀번호)
# 데이터: users, schedules, assignments, reviews, coach_profiles, auto_assign_rules
